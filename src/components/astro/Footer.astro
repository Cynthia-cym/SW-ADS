---
const productLinks = [
  { href: '/features', label: '功能介绍' },
  { href: '/platforms', label: '平台矩阵' },
  { href: '/pricing', label: '定价' },
];

const resourceLinks = [
  { href: '/docs', label: '使用文档' },
  { href: '/guides', label: '出海指南' },
  { href: '/cases', label: '案例中心' },
];

const companyLinks = [
  { href: '/about', label: '关于我们' },
  { href: '/team', label: '团队' },
  { href: '/careers', label: '招聘' },
  { href: '/contact', label: '联系我们' },
];

const socialLinks = [
  { icon: 'X', href: '#' },
  { icon: 'in', href: '#' },
  { icon: '▶', href: '#' },
];
---

<footer class="border-t border-white/[0.06] bg-brand-bg py-16">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center">
            <span class="text-white font-bold text-xs">SW</span>
          </div>
          <span class="font-bold text-lg text-white">SW ADS</span>
        </div>
        <p class="text-sm text-slate-400 leading-relaxed mb-4">
          AI原生的全球多平台出海广告投放平台
        </p>
        <div class="flex gap-3">
          {socialLinks.map((s) => (
            <a
              href={s.href}
              class="w-8 h-8 rounded-lg border border-white/10 flex items-center justify-center text-slate-400 hover:text-blue-400 hover:border-blue-500/30 transition-colors text-xs"
            >
              {s.icon}
            </a>
          ))}
        </div>
      </div>

      <!-- Product -->
      <div>
        <h4 class="font-semibold text-sm text-white mb-4">产品</h4>
        <ul class="space-y-2.5">
          {productLinks.map((l) => (
            <li>
              <a href={l.href} class="text-sm text-slate-400 hover:text-blue-400 transition-colors">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="font-semibold text-sm text-white mb-4">资源</h4>
        <ul class="space-y-2.5">
          {resourceLinks.map((l) => (
            <li>
              <a href={l.href} class="text-sm text-slate-400 hover:text-blue-400 transition-colors">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-semibold text-sm text-white mb-4">公司</h4>
        <ul class="space-y-2.5">
          {companyLinks.map((l) => (
            <li>
              <a href={l.href} class="text-sm text-slate-400 hover:text-blue-400 transition-colors">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-white/[0.06] flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-slate-500">
        &copy; 2026 SW ADS. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="/privacy" class="text-xs text-slate-500 hover:text-slate-400 transition-colors">隐私政策</a>
        <a href="/terms" class="text-xs text-slate-500 hover:text-slate-400 transition-colors">服务条款</a>
      </div>
    </div>
  </div>
</footer>
